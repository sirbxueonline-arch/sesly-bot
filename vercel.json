{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "includeFiles": "**", "maxLambdaSize": "50mb" }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/api/index.py" }
  ],
  "crons": [
    { "path": "/cron/digest",  "schedule": "0 16 * * *" },
    { "path": "/cron/hourly",  "schedule": "0 * * * *" }
  ]
}
