# ---- Meta WhatsApp Cloud API ----
# Pick any string for the verify token — paste the SAME string in the Meta dashboard.
META_VERIFY_TOKEN=pick-any-secret-string
# System User permanent access token (Meta Business Settings → System Users)
META_ACCESS_TOKEN=EAAG...
# Phone Number ID from Meta App → WhatsApp → API Setup (not the actual phone number).
# Required for sending booking notifications to business owners.
META_PHONE_NUMBER_ID=
META_GRAPH_VERSION=v20.0

# ---- AI ----
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Supabase ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ---- Optional ----
PORT=5001
FLASK_ENV=development
